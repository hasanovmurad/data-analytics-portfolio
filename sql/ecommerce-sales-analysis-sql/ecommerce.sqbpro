SELECT substr(order_date, 1, 7) AS month,
       SUM(revenue) AS total_revenue
FROM orders
GROUP BY month
ORDER BY month;</sql><sql name="SQL 2*">SELECT customer_name,
       SUM(revenue) AS total_revenue
FROM orders
GROUP BY customer_name
ORDER BY total_revenue DESC;
</sql><sql name="SQL 3*">SELECT AVG(revenue) AS average_order_value
FROM orders;</sql><sql name="SQL 4*">SELECT COUNT(*) AS total_orders
FROM orders;</sql><sql name="SQL 5*">SELECT substr(order_date, 1, 7) AS month,
       SUM(revenue) AS total_revenue
FROM orders
GROUP BY month
ORDER BY month;</sql><current_tab id="4"/></tab_sql></sqlb_project>
